{
    "paths": {
        "smlm_data": "ShareLoc_Data/data.csv",
        "pdb_data": "PDB_Data/7N85-assembly1.cif",
        "av_parameters": "av_parameter.json"
    },
    "execution": {
        "test_scoring_types": [
            "Tree",
            "GMM",
            "Distance"
        ],
        "target_cluster_id": null
    },
    "filtering": {
        "type": "random",
        "filter": {
            "x_range": [
                10000,
                12000
            ],
            "y_range": [
                0,
                5000
            ],
            "z_range": null
        },
        "random": {
            "size_percentage": 15
        }
    },
    "clustering": {
        "perform_geometric_merging": false,
        "min_cluster_size": 15,
        "min_npc_points": 120
    },
    "optimization": {
        "mode": "bayesian",
        "bayesian": {
            "run_sampling": true,
            "scoring_type": "GMM",
            "number_of_frames": 20,
            "monte_carlo_steps": 10
        },
        "frequentist": {
            "scoring_type": "Tree",
            "max_cg_steps": 200
        },
        "brownian": {
            "scoring_type": "Tree",
            "temperature_k": 300.0,
            "max_time_step_fs": 50000.0,
            "number_of_bd_steps": 500,
            "rmf_save_interval": 10
        }
    }
}